# ScaderLedsSandBot-specific overrides (Common sdkconfig.defaults provides the base)

# Serial Console - USB Serial JTAG (ESP32-S3)
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_ESP_CONSOLE_SECONDARY_USB_SERIAL_JTAG=n

# WiFi options - keep in IRAM for performance
CONFIG_ESP_WIFI_IRAM_OPT=y
CONFIG_ESP_WIFI_RX_IRAM_OPT=y

# WiFi options to help prevent WiFi errors
CONFIG_ESP_WIFI_STA_DISCONNECTED_PM_ENABLE=n

# RMT Configuration for reliable LED control with large strips
CONFIG_RMT_TX_ISR_CACHE_SAFE=y
CONFIG_RMT_RECV_FUNC_IN_IRAM=y

# Power management
CONFIG_PM_ENABLE=n
