{
    "SystemName": "ScaderOpener",
    "MQTTMan": {
        "enable": 1,
        "brokerHostname": "benbecula",
        "brokerPort": 1883,
        "clientID": "Scader",
        "topics": [
            {
                "name": "scaderIn",
                "inbound": 1,
                "path": "scader/in",
                "qos": 1
            },
            {
                "name": "scaderOut",
                "inbound": 0,
                "path": "scader/out",
                "qos": 1
            }
        ]
    },
    "Publish": {
        "enable": 1,
        "pubList": [
            {
                "topic": "ScaderOpener",
                "rates": [
                    {
                        "if": "scaderOut",
                        "protocol": "RICJSON",
                        "rateHz": 0.1
                    }
                ]
            }
        ]
    },
    "DevMan": {
        "Buses": {
            "buslist": [
                {
                    "name": "I2CA",
                    "type": "I2C",
                    "sdaPin": 41,
                    "sclPin": 42,
                    "i2cFreq": 100000,
                    "loopYieldMs": 20
                },
                {
                    "name": "SERA",
                    "type": "serial",
                    "uartNum": 2,
                    "rxPin": 5,
                    "txPin": 47,
                    "baudRate": 115200,
                    "minAfterSendMs": 5
                },
                {
                    "name": "BusBLE",
                    "type": "BusBLE"
                }
            ]
        },
        "Devices": [
            {
                "enable": 1,
                "class": "MotorControl",
                "name": "MotorControl",
                "bus": "SERA",
                "motion": {
                    "geom": "XYZ",
                    "blockDist": 10,
                    "allowOutOfBounds": 1,
                    "homeBeforeMove": 0,
                    "junctionDeviation": 0.05
                },
                "ramp": {
                    "rampTimerEn": 1,
                    "rampTimerUs": 100,
                    "pipelineLen": 100
                },
                "motorEn": {
                    "stepEnablePin": 4,
                    "stepEnLev": 0,
                    "stepDisableSecs": 1
                },
                "axes": [
                    {
                        "name": "X",
                        "params": {
                            "unitsPerRot": 360,
                            "stepsPerRot": 3600,
                            "maxSpeedUps": 10,
                            "maxAccUps2": 10
                        },
                        "driver": {
                            "driver": "TMC2209",
                            "hw": "local",
                            "addr": 0,
                            "stepPin": 15,
                            "dirnPin": 16,
                            "invDirn": 0,
                            "writeOnly": 0,
                            "extSenseOhms": 0.5,
                            "extVRef": 0,
                            "extMStep": 0,
                            "intpol": 1,
                            "microsteps": 1,
                            "rmsAmps": 0.5,
                            "holdModeOrFactor": 0.5,
                            "holdDelay": 1,
                            "pwmFreqKHz": 35
                        }
                    }
                ]
            },
            {
                "enable": 1,
                "class": "Buzzer",
                "name": "Buzzer",
                "pin": 21,
                "ledcTimer": 1,
                "ledcChan": 0,
                "volume": 20
            },
            {
                "enable": 1,
                "class": "LightSensors",
                "name": "Light",
                "type": "LightV1",
                "Ambient": [
                    {
                        "chan": 7
                    }
                ]
            },
            {
                "enable": 1,
                "class": "HX711",
                "name": "HX711",
                "clkPin": 38,
                "dataPin": 48
            },
            {
                "enable": 1,
                "class": "OutputFETS",
                "pins": [
                    10,
                    11
                ]
            }
        ]
    },
    "ScaderOpener": {
        "DoorRemainOpenTimeSecs": 45,
        "DoorTimeToOpenSecs": 20,
        "DoorOpenAngleDegs": 0,
        "DoorClosedAngleDegs": 0,
        "consvPirPin": 17,
        "consvButtonPin": 6,
        "MotorOnTimeAfterMoveSecs": 5,
        "MaxMotorCurrentAmps": 0.4,
        "ForceThresholdN": 5,
        "uiModule": {
            "rxPin": 39,
            "txPin": 40,
            "uartNum": 1,
            "baudRate": 115200
        }
    }
}
