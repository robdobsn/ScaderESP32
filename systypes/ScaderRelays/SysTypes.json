{
    "SystemName": "ScaderRelays",
    "NetMan": {
        "enable": 1,
        "wifiSTAEn": 0,
        "wifiAPEn": 0,
        "ethEn": 1,
        "wifiSSID": "",
        "wifiPW": "",
        "wifiSTAScanThreshold": "OPEN",
        "wifiAPSSID": "",
        "wifiAPPW": "",
        "wifiAPChannel": 1,
        "wifiAPMaxConn": 4,
        "wifiAPAuthMode": "WPA2_PSK",
        "ethLanChip": "LAN87XX",
        "ethPowerPin": 12,
        "ethMDCPin": 23,
        "ethMDIOPin": 18,
        "ethPhyAddr": 0,
        "ethPhyRstPin": -1,
        "NTPServer": "pool.ntp.org",
        "timezone": "UTC",
        "logLevel": "D"
    },
    "MQTTMan": {
        "enable": 1,
        "brokerHostname": "benbecula",
        "brokerPort": 1883,
        "clientID": "Scader",
        "topics": [
            {
                "name": "scaderIn",
                "inbound": 1,
                "path": "scader/in",
                "qos": 1
            },
            {
                "name": "scaderOut",
                "inbound": 0,
                "path": "scader/out",
                "qos": 1
            },
            {
                "name": "scaderGas",
                "inbound": 0,
                "path": "scader/gas",
                "qos": 1
            },
            {
                "name": "scaderElec",
                "inbound": 0,
                "path": "scader/elec",
                "qos": 1
            },
            {
                "name": "scaderBTHome",
                "inbound": 0,
                "path": "scader/bthome",
                "qos": 1
            }
        ]
    },
    "BLEMan": {
        "enable": 1,
        "central": 1,
        "peripheral": 0,
        "scanIntervalMs": 200,
        "scanWindowMs": 150,
        "scanPassive": 1,
        "scanNoDup": 0,
        "scanLimited": 0,
        "scanBTHome": 1,
        "busConnName": "BusBLE",
        "logLevel": "D",
        "nimLogLev": "E"
    },
    "Publish": {
        "enable": 1,
        "pubList": [
            {
                "topic": "ScaderRelays",
                "rates": [
                    {
                        "if": "scaderOut",
                        "protocol": "RICJSON",
                        "rateHz": 0.1
                    }
                ]
            },
            {
                "topic": "ScaderPulseCounter",
                "rates": [
                    {
                        "if": "scaderOut",
                        "protocol": "RICJSON",
                        "rateHz": 0.01
                    },
                    {
                        "if": "scaderGas",
                        "protocol": "RICJSON",
                        "rateHz": 0.1
                    }
                ]
            },
            {
                "topic": "ScaderElecMeters",
                "rates": [
                    {
                        "if": "scaderOut",
                        "protocol": "RICJSON",
                        "rateHz": 0.01
                    },
                    {
                        "if": "scaderElec",
                        "protocol": "RICJSON",
                        "rateHz": 0.1
                    }
                ]
            },
            {
                "topic": "ScaderBTHome",
                "trigger": "change",
                "rates": [
                    {
                        "if": "scaderOut",
                        "protocol": "RICJSON"
                    },
                    {
                        "if": "scaderBTHome",
                        "protocol": "RICJSON"
                    }
                ]
            },
            {
                "topic": "devjson",
                "rates": [
                    {
                        "if": "scaderOut",
                        "protocol": "RICJSON",
                        "rateHz": 0.1
                    }
                ]
            }
        ]
    },
    "ScaderRelays": {
        "maxElems": 24,
        "SPI_MOSI": 33,
        "SPI_MISO": 32,
        "SPI_CLK": 16,
        "SPI_CS1": 4,
        "SPI_CS2": 5,
        "SPI_CS3": 13,
        "ONOFF_KEY": 34,
        "mainsSyncPin": 35,
        "enableMainsSync": true
    },
    "ScaderElecMeters": {
        "maxElems": 16,
        "SPI_MOSI": 33,
        "SPI_MISO": 32,
        "SPI_CLK": 16,
        "SPI_CS1": 15,
        "SPI_CS2": 14,
        "taskCore": 1,
        "taskStack": 5000,
        "taskPriority": 2,
        "calibADCToAmps": 0.0889
    },
    "ScaderLEDPix": {
        "strips": [
            {
                "pin": 21,
                "num": 14
            }
        ],
        "brightnessPC": 20
    },
    "ScaderPulseCounter": {
        "pulseCounterPin": 39
    },
    "DevMan": {
        "Buses": {
            "buslist": [
                {
                    "name": "BusBLE",
                    "type": "BusBLE"
                }
            ]
        }
    }
}
